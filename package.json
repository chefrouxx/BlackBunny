{
  "name": "blackbunny",
  "description": "BlackBunny Social App",
  "author": "BlackBunny Team",
  "main": "electron-main.js",
  "version": "1.0.0",
  "scripts": {
    "start": "electron .",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:build": "expo export --platform web --output-dir web-build",
    "desktop:build:mac": "npm run web:build && electron-builder --mac",
    "desktop:build:win": "npm run web:build && electron-builder --win",
    "desktop:build": "npm run web:build && electron-builder --mac --win",
    "dist": "npm run web:build && electron-builder",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "electron": "^29.4.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "build": {
    "appId": "com.blackbunny.app",
    "productName": "BlackBunny",
    "directories": {
      "output": "dist"
    },
    "extraMetadata": {
      "main": "electron-main.js"
    },
    "files": [
      "electron-main.js",
      "web-build/**/*"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": ["nsis", "msi"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "private": true
}
